# --- Resend (отправка email) ---
# 1) зарегистрируйся на https://resend.com (бесплатно)
# 2) создай api key в dashboard и вставь сюда
# 3) пока домен не подключён - оставь from = onboarding@resend.dev
#    (письма уйдут только на адрес, привязанный к аккаунту resend)
# 4) когда подключишь musictech.art - смени на noreply@musictech.art
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Upstash Redis (хранилище кодов и аккаунтов) ---
# 1) зарегистрируйся на https://upstash.com (бесплатно, 10000 команд/день)
# 2) создай Redis Database, регион - eu-west-1 или fra1
# 3) скопируй REST URL и REST Token (раздел "REST API")
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# --- JWT ---
# любая длинная случайная строка, например:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=please-replace-with-a-long-random-secret-at-least-32-chars

# --- сайт ---
# корень сайта, попадает в ссылки восстановления пароля
APP_URL=https://musictech.art
