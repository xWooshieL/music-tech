---
const features = [
  {
    icon: "music",
    title: "Следит за партитурой",
    text: "Гибрид Hidden Markov Model + On-Line Time Warping локализует ваше место в нотах с точностью до одного аккорда. Якорный resync восстанавливает синхронизацию даже если вы пропустили целую страницу.",
  },
  {
    icon: "wave",
    title: "Опережающий темп",
    text: "Лёгкий RL-агент видит состояние трекера и предсказывает темп на 200–500 мс вперёд. Оркестр успевает развернуть rubato вместе с вами, а не отставать.",
  },
  {
    icon: "cpu",
    title: "20 мс end-to-end",
    text: "Чистый numpy в горячем пути, без GPU и облака. Бюджет 20 мс держится даже на крупных пьесах в 4000+ состояний — концерты Рахманинова проходят без задержек.",
  },
  {
    icon: "midi",
    title: "MIDI и микрофон",
    text: "Подключите digital piano по MIDI или используйте обычный микрофон (β). Поддерживаются Yamaha, Roland, Casio, Kawai, любые USB и Bluetooth-клавиатуры.",
  },
  {
    icon: "lock",
    title: "Никакого облака",
    text: "Всё работает локально на вашем компьютере. Партитура, исполнение и метрики никуда не отправляются — даже метаданные. Open-source, можно проверить.",
  },
  {
    icon: "open",
    title: "Open-source ядро",
    text: "Код на GitHub под MIT-лицензией. Можно форкнуть, дописать свой следящий, дообучить RL-агента под свой стиль игры или предложить улучшение в исходный код.",
  },
];
---

<section id="features" class="py-24 md:py-32">
  <div class="container-soft">
    <div class="reveal text-center max-w-2xl mx-auto">
      <span class="pill">возможности</span>
      <h2 class="mt-4 font-display text-4xl md:text-5xl font-bold text-ink-900 tracking-tight">
        Шесть причин, почему MusicTech &mdash; не очередная фонограмма
      </h2>
      <p class="mt-4 text-ink-600 text-lg">
        Каждая возможность подкреплена научной статьёй и реальным кодом в репозитории.
      </p>
    </div>

    <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f, i) => (
        <div class="reveal card" style={`transition-delay: ${i * 60}ms`}>
          <div class="size-11 rounded-xl bg-brand-50 border border-brand-200 flex items-center justify-center text-brand-700">
            {f.icon === "music" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            )}
            {f.icon === "wave" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h2"/><path d="M6 12V6"/><path d="M10 12v6"/><path d="M14 12V3"/><path d="M18 12v9"/><path d="M22 12h-2"/></svg>
            )}
            {f.icon === "cpu" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2"/></svg>
            )}
            {f.icon === "midi" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M7 10v4M10 10v4M13 10v4M16 10v4"/></svg>
            )}
            {f.icon === "lock" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            )}
            {f.icon === "open" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            )}
          </div>
          <h3 class="mt-5 font-display font-bold text-lg text-ink-900">{f.title}</h3>
          <p class="mt-2 text-ink-600 leading-relaxed text-sm">{f.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
