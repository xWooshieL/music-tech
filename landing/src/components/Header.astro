---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// якорные ссылки (#features и т.п.) на главной — скроллят, на других
// страницах — ведут на /#anchor. JS подстроит href при необходимости.
const nav = [
  { href: "#features", label: "Возможности",     anchor: true  },
  { href: "#how",      label: "Как это работает", anchor: true  },
  { href: "#download", label: "Скачать",          anchor: true  },
  { href: "#faq",      label: "FAQ",              anchor: true  },
  { href: `${base}/about`, label: "О нас",        anchor: false },
];
---

<header class="sticky top-0 z-40 backdrop-blur border-b border-ink-200/60 bg-white/70">
  <div class="container-soft flex h-16 items-center justify-between gap-4">
    <a href={`${base}/`} class="flex items-center gap-2 group shrink-0">
      <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
        <defs>
          <linearGradient id="hg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%"  stop-color="#34d399" />
            <stop offset="100%" stop-color="#059669" />
          </linearGradient>
        </defs>
        <rect x="2" y="2" width="28" height="28" rx="8" fill="url(#hg)" />
        <path d="M11 9v10.2a3 3 0 1 1-2-2.83V9z" fill="#fff" />
        <circle cx="22.5" cy="11" r="1.4" fill="#fff" />
        <circle cx="22.5" cy="15" r="1.4" fill="#fff" />
        <circle cx="22.5" cy="19" r="1.4" fill="#fff" />
      </svg>
      <span class="font-display text-lg font-bold tracking-tight text-ink-900 group-hover:text-brand-700 transition">
        Music<span class="text-brand-500">Tech</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-7 text-sm font-medium text-ink-700">
      {nav.map((n) => (
        <a
          href={n.href}
          data-anchor={n.anchor ? "1" : null}
          class="nav-link hover:text-brand-700 transition"
        >
          {n.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <!-- единственная auth-кнопка: меняет текст и href в зависимости от того,
           авторизован пользователь или нет. для гостей - "Войти" → /login,
           для залогиненных - "Личный кабинет" → /account. больше никаких
           кнопок в шапке нет: ни админки, ни выхода, ни 'кабинет' отдельно. -->
      <a
        id="auth-cta"
        href={`${base}/login`}
        class="btn-primary hidden sm:inline-flex"
        data-href-anon={`${base}/login`}
        data-href-user={`${base}/account`}
      >
        Войти
      </a>

      <!-- mobile hamburger -->
      <button
        id="menu-btn"
        aria-label="Меню"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="lg:hidden inline-flex items-center justify-center size-10 rounded-lg border border-ink-200 hover:bg-ink-50 transition"
      >
        <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"  />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="menu-icon-close" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </button>
    </div>
  </div>

  <!-- mobile drawer -->
  <nav
    id="mobile-menu"
    class="lg:hidden hidden border-t border-ink-200 bg-white/95 backdrop-blur"
  >
    <div class="container-soft py-4 flex flex-col gap-1">
      {nav.map((n) => (
        <a
          href={n.href}
          data-anchor={n.anchor ? "1" : null}
          class="nav-link mobile-link block px-3 py-3 rounded-lg text-base font-medium text-ink-800 hover:bg-ink-50"
        >
          {n.label}
        </a>
      ))}
      <hr class="my-2 border-ink-200" />
      <a
        id="auth-cta-mobile"
        href={`${base}/login`}
        class="btn-primary mt-2 mobile-link"
        data-href-anon={`${base}/login`}
        data-href-user={`${base}/account`}
      >
        Войти
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  // ───────────── hamburger toggle ─────────────
  (function () {
    const btn   = document.getElementById("menu-btn");
    const menu  = document.getElementById("mobile-menu");
    const open  = document.getElementById("menu-icon-open");
    const close = document.getElementById("menu-icon-close");
    if (!btn || !menu) return;

    function setOpen(state) {
      btn.setAttribute("aria-expanded", state ? "true" : "false");
      menu.classList.toggle("hidden", !state);
      open.classList.toggle("hidden", state);
      close.classList.toggle("hidden", !state);
      document.body.style.overflow = state ? "hidden" : "";
    }

    btn.addEventListener("click", () => {
      setOpen(menu.classList.contains("hidden"));
    });

    // закрываем drawer при клике по любой ссылке внутри
    menu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => setOpen(false));
    });
  })();

  // ───────────── якорные ссылки с других страниц ─────────────
  // если href="#features", а текущая страница не "/" — заменяем на "/#features"
  (function () {
    const path = location.pathname.replace(/\/+$/, "");
    const onHome = path === "" || path === "/index" || path === "/index.html";
    if (onHome) return; // на главной — оставляем как есть, скролл сработает

    document.querySelectorAll('a[data-anchor="1"]').forEach((a) => {
      const href = a.getAttribute("href") || "";
      if (href.startsWith("#")) {
        a.setAttribute("href", "/" + href);
      }
    });
  })();

  // ───────────── единственная auth-кнопка в шапке ─────────────
  // правила (без вариантов):
  //   гость         → "Войти"          → /login
  //   авторизован   → "Личный кабинет" → /account
  // никаких 'Админ', 'Выйти', 'Кабинет' рядом не существует. админка
  // и выход доступны только изнутри /account.
  (function () {
    function safeGet(key) {
      try { return localStorage.getItem(key); } catch { return null; }
    }
    function safeRemove(key) {
      try { localStorage.removeItem(key); } catch {}
    }
    function safeSet(key, val) {
      try { localStorage.setItem(key, val); } catch {}
    }

    const ctas = Array.from(document.querySelectorAll("#auth-cta, #auth-cta-mobile"));
    if (!ctas.length) return;

    function setMode(mode) {
      // mode: 'anon' | 'user'
      const label = mode === "user" ? "Личный кабинет" : "Войти";
      ctas.forEach((el) => {
        const href = el.getAttribute(mode === "user" ? "data-href-user" : "data-href-anon");
        if (href) el.setAttribute("href", href);
        el.textContent = label;
      });
    }

    // первичный рендер по наличию токена в localStorage
    const token = safeGet("musictech.token");
    setMode(token ? "user" : "anon");

    // если токен есть - сверяем с сервером, чтобы при истёкшем токене
    // вернуть гостевой режим. роль в шапке не показываем никак.
    if (!token) return;

    fetch("/api/auth/me", {
      headers: { authorization: "Bearer " + token },
      credentials: "include",
    })
      .then((r) => r.json())
      .then((b) => {
        if (b && b.ok && b.user) {
          safeSet("musictech.email", b.user.email);
          safeSet("musictech.name",  b.user.name || "");
          safeSet("musictech.role",  b.user.role || "user");
          setMode("user");
        } else {
          safeRemove("musictech.token");
          safeRemove("musictech.email");
          safeRemove("musictech.name");
          safeRemove("musictech.role");
          setMode("anon");
        }
      })
      .catch(() => { /* офлайн — оставляем как есть */ });
  })();
</script>
