---
import "@fontsource-variable/inter";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MusicTech — виртуальный оркестр в реальном времени",
  description =
    "MusicTech аккомпанирует солисту: классические трекеры партитуры HMM/OLTW " +
    "плюс RL-агент опережающего темпа. Open-source, работает локально, без задержек.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#10b981" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}/favicon.svg`} />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="canonical" href="https://musictech.art/" />

    <title>{title}</title>
  </head>

  <body class="relative overflow-x-hidden">
    <!-- декоративные фоновые blob-ы -->
    <div class="blob bg-brand-200 w-[600px] h-[600px] -top-40 -left-40"></div>
    <div
      class="blob bg-indigo-200 w-[500px] h-[500px] top-[40%] -right-40"
      style="animation-delay: -8s"
    >
    </div>

    <Header />

    <main class="relative">
      <slot />
    </main>

    <Footer />

    <!-- scroll-reveal через IntersectionObserver, без зависимостей.
         флаг js-ready включает анимацию только когда JS реально подгрузился.
         если no-js или скрипт упал - контент остаётся виден -->
    <script is:inline>
      // включаем анимации сразу после парсинга, до DOMContentLoaded
      document.documentElement.classList.add("js-ready");

      const reveal = () => {
        const els = document.querySelectorAll(".reveal");
        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
        );
        els.forEach((el) => io.observe(el));
      };

      if (document.readyState !== "loading") reveal();
      else document.addEventListener("DOMContentLoaded", reveal);
    </script>
  </body>
</html>
