---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="Войти — MusicTech"
  description="Авторизация в MusicTech. Логин синхронизируется с десктопным приложением для активации лицензии."
>
  <section class="container-soft py-20 md:py-28">
    <div class="reveal mx-auto max-w-md">
      <div class="text-center mb-8">
        <span class="pill">вход</span>
        <h1 class="mt-4 font-display text-4xl font-bold text-ink-900 tracking-tight">
          С возвращением!
        </h1>
        <p class="mt-2 text-ink-600">
          Один аккаунт — для сайта и для приложения MusicTech.
        </p>
      </div>

      <form
        id="login-form"
        class="card space-y-5"
        autocomplete="on"
      >
        <label class="block">
          <span class="block text-sm font-semibold text-ink-800 mb-1.5">E-mail</span>
          <input
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm
                   bg-white focus:border-brand-500 focus:ring focus:ring-brand-100
                   outline-none transition"
          />
        </label>

        <label class="block">
          <span class="flex items-center justify-between text-sm font-semibold text-ink-800 mb-1.5">
            <span>Пароль</span>
            <a href={`${base}/forgot-password`} class="text-xs font-medium link">забыли пароль?</a>
          </span>
          <input
            name="password"
            type="password"
            required
            minlength="6"
            placeholder="••••••••"
            class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm
                   bg-white focus:border-brand-500 focus:ring focus:ring-brand-100
                   outline-none transition"
          />
        </label>

        <label class="flex items-center gap-2 text-sm text-ink-600 select-none">
          <input type="checkbox" name="remember" class="size-4 accent-brand-500" />
          Запомнить меня на этом устройстве
        </label>

        <button
          type="submit"
          class="btn-primary w-full text-base py-3.5"
        >
          Войти
        </button>

        <p
          id="login-error"
          class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"
        ></p>

        <div class="relative my-1 text-center text-xs text-ink-400">
          <span class="bg-white px-3 relative z-10">или</span>
          <span class="absolute inset-x-0 top-1/2 h-px bg-ink-200"></span>
        </div>

        <button type="button" class="btn-ghost w-full">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.01-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.76 2.7 1.25 3.36.95.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.05.78 2.12 0 1.53-.01 2.77-.01 3.15 0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12c0-6.35-5.15-11.5-11.5-11.5z"/></svg>
          Войти через GitHub
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-ink-500">
        Нет аккаунта? <a href={`${base}/register`} class="link font-medium">Зарегистрироваться</a>
      </p>

      <p class="mt-3 text-center text-xs text-ink-400">
        Нажимая «войти», вы соглашаетесь с
        <a href={`${base}/terms`} class="link">условиями использования</a>
        и
        <a href={`${base}/privacy`} class="link">политикой конфиденциальности</a>.
      </p>
    </div>
  </section>

  <script is:inline>
    const form     = document.getElementById("login-form");
    const errorBox = document.getElementById("login-error");

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!errorBox) return;
      errorBox.classList.add("hidden");

      const data = new FormData(form);
      const email    = String(data.get("email")    || "").trim();
      const password = String(data.get("password") || "");

      if (!email.includes("@") || password.length < 6) {
        errorBox.textContent = "проверьте e-mail и пароль (минимум 6 символов)";
        errorBox.classList.remove("hidden");
        return;
      }

      try {
        const res = await fetch("/api/auth/login", {
          method:  "POST",
          headers: { "content-type": "application/json" },
          body:    JSON.stringify({ email, password }),
        });
        const body = await res.json();
        if (!res.ok || !body?.ok) {
          throw new Error(body?.error || `ошибка ${res.status}`);
        }
        localStorage.setItem("musictech.token", body.token);
        localStorage.setItem("musictech.email", email);
        if (body.name) localStorage.setItem("musictech.name", body.name);

        const baseUrl = location.pathname.replace(/\/login\/?$/, "");
        window.location.href = `${baseUrl}/download?ok=1`;
      } catch (err) {
        errorBox.textContent = err.message;
        errorBox.classList.remove("hidden");
      }
    });
  </script>
</Base>
