---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="Новый пароль — MusicTech"
  description="Установите новый пароль для своего аккаунта MusicTech."
>
  <section class="container-soft py-20 md:py-28">
    <div class="reveal mx-auto max-w-md">
      <div class="text-center mb-8">
        <span class="pill">новый пароль</span>
        <h1 class="mt-4 font-display text-4xl font-bold text-ink-900 tracking-tight">
          Установите новый пароль
        </h1>
        <p class="mt-2 text-ink-600">
          Ссылка действует 30 минут и работает один раз.
        </p>
      </div>

      <form id="reset-form" class="card space-y-5">
        <input id="reset-token" type="hidden" name="token" />

        <label class="block">
          <span class="block text-sm font-semibold text-ink-800 mb-1.5">Новый пароль</span>
          <input
            name="new_password"
            type="password"
            required
            minlength="8"
            placeholder="••••••••"
            class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm
                   bg-white focus:border-brand-500 focus:ring focus:ring-brand-100
                   outline-none transition"
          />
          <span class="block mt-1.5 text-xs text-ink-500">
            минимум 8 символов
          </span>
        </label>

        <label class="block">
          <span class="block text-sm font-semibold text-ink-800 mb-1.5">Повторите пароль</span>
          <input
            name="confirm"
            type="password"
            required
            minlength="8"
            placeholder="••••••••"
            class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm
                   bg-white focus:border-brand-500 focus:ring focus:ring-brand-100
                   outline-none transition"
          />
        </label>

        <button type="submit" id="reset-submit" class="btn-primary w-full text-base py-3.5">
          Сохранить пароль
        </button>

        <p
          id="reset-error"
          class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"
        ></p>
      </form>

      <p class="mt-6 text-center text-sm text-ink-500">
        Передумали? <a href={`${base}/login`} class="link font-medium">Войти со старым паролем</a>
      </p>
    </div>
  </section>

  <script is:inline>
    const params = new URLSearchParams(location.search);
    const token = params.get("token") || "";
    const tokenInput = document.getElementById("reset-token");
    if (tokenInput) tokenInput.value = token;

    const form    = document.getElementById("reset-form");
    const error   = document.getElementById("reset-error");
    const submit  = document.getElementById("reset-submit");

    if (!token) {
      error.textContent = "ссылка некорректна — запросите восстановление заново";
      error.classList.remove("hidden");
      submit.setAttribute("disabled", "disabled");
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!error || !submit) return;
      error.classList.add("hidden");

      const data = new FormData(form);
      const np = String(data.get("new_password") || "");
      const cp = String(data.get("confirm")      || "");
      if (np !== cp) {
        error.textContent = "пароли не совпадают";
        error.classList.remove("hidden");
        return;
      }

      submit.textContent = "Сохраняем...";
      submit.setAttribute("disabled", "disabled");

      try {
        const res = await fetch("/api/auth/reset-password", {
          method:  "POST",
          headers: { "content-type": "application/json" },
          body:    JSON.stringify({ token, new_password: np }),
        });
        const body = await res.json();
        if (!res.ok || !body?.ok) {
          throw new Error(body?.error || `ошибка ${res.status}`);
        }
        if (body.token) localStorage.setItem("musictech.token", body.token);
        if (body.name)  localStorage.setItem("musictech.name",  body.name);
        const baseUrl = location.pathname.replace(/\/reset-password\/?$/, "");
        window.location.href = `${baseUrl}/download?password_updated=1`;
      } catch (err) {
        error.textContent = err.message;
        error.classList.remove("hidden");
        submit.textContent = "Сохранить пароль";
        submit.removeAttribute("disabled");
      }
    });
  </script>
</Base>
